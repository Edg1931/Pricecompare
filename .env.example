# Postgres (Supabase). https://supabase.com — Project Settings > Database > Connection string.
# DATABASE_URL = POOLED connection (Transaction mode, port 6543) — used by the app at runtime.
# DIRECT_URL   = DIRECT connection (port 5432) — used for migrations / prisma db push.
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Supabase Storage for photos. Create a PUBLIC bucket named "item-photos".
# Service role key: Project Settings > API > service_role (KEEP SECRET, server-only).
SUPABASE_URL="https://PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_BUCKET="item-photos"

# Anthropic (required for vision + research). https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-sonnet-4-6"

# eBay Browse API (optional, improves price accuracy). https://developer.ebay.com
# Sold/completed comps (the most accurate signal) activate automatically with
# these same credentials once your app is approved for the eBay Marketplace
# Insights API. Until then the estimate uses active listings + web research.
EBAY_CLIENT_ID=""
EBAY_CLIENT_SECRET=""

# Protects the scheduled re-check endpoint (/api/cron/recheck). Set this to a
# long random string and add the same value as a Bearer token on the Vercel
# cron job. If unset, the endpoint is unauthenticated — set it in production.
CRON_SECRET=""
