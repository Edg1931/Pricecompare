generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Item {
  id                String   @id @default(cuid())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Identification (from Claude vision)
  name              String
  brand             String?
  model             String?
  category          String?
  condition         String?
  attributes        String? // JSON array of {label, value}
  identConfidence   Float? // 0..1
  identNotes        String?
  searchQuery       String?

  // Pricing (aggregated from eBay + web research)
  recommendedLow    Float?
  recommendedMedian Float?
  recommendedHigh   Float?
  priceConfidence   Float? // 0..1
  sampleSize        Int     @default(0)
  marketContext     String?

  // Deal analysis
  askingPrice       Float?
  dealScore         Int? // 0..100
  verdict           String? // STEAL | GOOD | FAIR | OVERPRICED
  bestPlatform      String?
  netProceeds       String? // JSON array of {platform, net, feePct}
  analysisSummary   String?

  // Listing kit (Claude generated)
  listingTitle      String?
  listingDescription String?

  // Estimated sold-price trend over time (JSON: current/m3/m6/y1 + direction)
  priceTrend        String?

  // Demand signal (JSON: sell-through score, days-to-sell, seasonality)
  demand            String?

  status            String  @default("analyzed")
  notes             String?

  // Flip / P&L tracking (filled in as you buy and sell)
  purchasePrice     Float?    // what you actually paid
  boughtAt          DateTime?
  soldPrice         Float?    // actual sale price
  soldMarketplace   String?   // where it sold
  soldFees          Float?    // actual platform fees (overrides the estimate)
  shippingCost      Float?    // shipping you paid out of pocket
  soldAt            DateTime?

  photos            Photo[]
  comps             Comp[]
  snapshots         PriceSnapshot[]
}

// Business expenses (mileage, supplies, etc.) for true net profit and taxes.
model Expense {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  type        String   @default("other") // mileage | supplies | shipping | fees | other
  description String?
  amount      Float    @default(0)
  miles       Float?
  createdAt   DateTime @default(now())
}

// A point-in-time record of the estimated resale price, captured on each
// analyze/re-analyze so a real price history builds up over time.
model PriceSnapshot {
  id         String   @id @default(cuid())
  itemId     String
  item       Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  low        Float?
  median     Float?
  high       Float?
  sampleSize Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([itemId])
}

model Photo {
  id        String   @id @default(cuid())
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Comp {
  id          String   @id @default(cuid())
  itemId      String
  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  source      String // ebay | etsy | mercari | facebook | swappa | poshmark | stockx | web
  title       String
  price       Float
  currency    String   @default("USD")
  url         String?
  condition   String?
  listingType String   @default("active") // active | sold
  capturedAt  DateTime @default(now())

  @@index([itemId])
}
